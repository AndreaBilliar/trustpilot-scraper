# Target company URL on Trustpilot
TARGET_URL="https://trustpilot.com/review/www.example.com"

# Email address for your Trustpilot account (must be created beforehand)
USER_EMAIL="your_email@example.com"

# Pagination settings for scraping
START_PAGE=1
END_PAGE=10

# Enable Headless mode (no GUI): True or False
HEADLESS=False

# Optional: If the script fails with a "session not created" error, 
# uncomment the line below and enter your major Chrome browser version.
# CHROME_VERSION=146